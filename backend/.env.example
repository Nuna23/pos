# Backend environment (consumed by src/config.php via getenv()).
# docker-compose.yml sets these for local dev; on cPanel the hardcoded
# fallbacks in src/config.php are used instead.

# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=baanrac1_crepepos
DB_USER=baanrac1_crepepos
DB_PASS=Jlhome2026

# App
APP_TZ=Asia/Bangkok
FRONTEND_URL=http://localhost:3000

# LINE Messaging API (low-stock alert to the owner). Leave blank to disable.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_NOTIFY_USER_ID=

# Web Push VAPID (needs PHP 7.3+ to actually send). Leave blank to disable.
# Generate with: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_EMAIL=mailto:admin@example.com

# Shared secret protecting GET /api/internal/stock-alert
CRON_SECRET=changeme
